# URL du projet Supabase (Project Settings → API), sans suffixe /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé publique publishable / anon (Project Settings → API) — jamais la service_role key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Sans ces deux variables, l'app démarre en mode local avec des données mockées
# (aucune sauvegarde, aucune authentification).
